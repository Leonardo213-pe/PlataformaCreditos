@model PlataformaCreditosWeb.Models.SolicitudCredito

@{
    ViewData["Title"] = $"Rechazar Solicitud #{Model.Id}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Analista" asp-action="Index">
                Panel Analista
            </a>
        </li>
        <li class="breadcrumb-item active">
            Rechazar Solicitud #@Model.Id
        </li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">

            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">❌ Rechazar Solicitud #@Model.Id</h4>
            </div>

            <div class="card-body">

                <!-- Mostrar errores -->
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <!-- Resumen -->
                <div class="alert alert-light border mb-4">
                    <p><strong>Cliente:</strong> @Model.Cliente.Usuario.NombreCompleto</p>
                    <p><strong>Email:</strong> @Model.Cliente.Usuario.Email</p>
                    <p><strong>Monto solicitado:</strong> S/ @Model.MontoSolicitado.ToString("N2")</p>
                    <p><strong>Ingresos mensuales:</strong> S/ @Model.Cliente.IngresosMensuales.ToString("N2")</p>
                </div>

                <!-- Formulario -->
                <form method="post" asp-controller="Analista" asp-action="Rechazar">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="solicitudId" value="@Model.Id" />

                    <div class="mb-4">
                        <label class="form-label fw-bold">
                            Motivo de rechazo
                            <span class="text-danger">*</span>
                        </label>

                        <textarea name="motivoRechazo"
                                  class="form-control"
                                  rows="4"
                                  maxlength="500"></textarea>

                        <span class="text-danger">
                            @Html.ValidationMessage("motivoRechazo")
                        </span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-danger"
                                onclick="return confirm('¿Confirmar rechazo?')">
                            ❌ Confirmar rechazo
                        </button>

                        <a asp-controller="Analista"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Cancelar
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>