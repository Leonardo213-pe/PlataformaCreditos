@model PlataformaCreditosWeb.Models.SolicitudCredito
@{
    ViewData["Title"] = $"Solicitud #{Model.Id}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Solicitudes"
               asp-action="MisSolicitudes">Mis Solicitudes</a>
        </li>
        <li class="breadcrumb-item active">Solicitud #@Model.Id</li>
    </ol>
</nav>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Solicitud #@Model.Id</h4>
        @switch (Model.Estado)
        {
            case PlataformaCreditosWeb.Models.EstadoSolicitud.Pendiente:
                <span class="badge bg-warning text-dark fs-6">Pendiente</span>
                break;
            case PlataformaCreditosWeb.Models.EstadoSolicitud.Aprobado:
                <span class="badge bg-success fs-6">Aprobado</span>
                break;
            case PlataformaCreditosWeb.Models.EstadoSolicitud.Rechazado:
                <span class="badge bg-danger fs-6">Rechazado</span>
                break;
        }
    </div>
    <div class="card-body">
        <table class="table table-borderless">
            <tr>
                <td><strong>Monto solicitado</strong></td>
                <td>S/ @Model.MontoSolicitado.ToString("N2")</td>
            </tr>
            <tr>
                <td><strong>Fecha de solicitud</strong></td>
                <td>@Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            <tr>
                <td><strong>Ingresos mensuales</strong></td>
                <td>S/ @Model.Cliente.IngresosMensuales.ToString("N2")</td>
            </tr>
            <tr>
                <td><strong>Monto máximo permitido</strong></td>
                <td>S/ @Model.Cliente.MontoMaximo.ToString("N2")</td>
            </tr>
            @if (Model.Estado == PlataformaCreditosWeb.Models.EstadoSolicitud.Rechazado
                && !string.IsNullOrEmpty(Model.MotivoRechazo))
            {
                <tr>
                    <td><strong>Motivo de rechazo</strong></td>
                    <td class="text-danger">@Model.MotivoRechazo</td>
                </tr>
            }
        </table>
    </div>
    <div class="card-footer">
        <a asp-controller="Solicitudes" asp-action="MisSolicitudes"
           class="btn btn-outline-secondary">
            ← Volver
        </a>
    </div>
</div>