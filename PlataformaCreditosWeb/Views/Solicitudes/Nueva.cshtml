@{
    ViewData["Title"] = "Nueva Solicitud";
    var montoMaximo = ViewBag.MontoMaximo as decimal? ?? 0;
    var ingresos = ViewBag.IngresosMensuales as decimal? ?? 0;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">+ Nueva Solicitud de Crédito</h2>

        <div class="card shadow-sm mb-3">
            <div class="card-body bg-light">
                <p class="mb-1">
                    <strong>Tus ingresos mensuales:</strong>
                    S/ @ingresos.ToString("N2")
                </p>
                <p class="mb-0">
                    <strong>Monto máximo que puedes solicitar:</strong>
                    <span class="text-success fw-bold">
                        S/ @montoMaximo.ToString("N2")
                    </span>
                    <small class="text-muted">(10x tus ingresos)</small>
                </p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post" asp-controller="Solicitudes"
                      asp-action="Nueva">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label fw-bold">
                            Monto a solicitar (S/)
                        </label>
                        <input name="montoSolicitado"
                               type="number"
                               class="form-control form-control-lg"
                               placeholder="Ej: 5000"
                               min="1"
                               max="@montoMaximo"
                               step="0.01"
                               required />
                        <div class="form-text">
                            Ingresa un monto entre S/ 1.00 y
                            S/ @montoMaximo.ToString("N2")
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg">
                            ✅ Enviar solicitud
                        </button>
                        <a asp-controller="Solicitudes"
                           asp-action="MisSolicitudes"
                           class="btn btn-outline-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="alert alert-info mt-3">
            <strong>ℹ Información:</strong>
            <ul class="mb-0 mt-1">
                <li>Solo puedes tener una solicitud Pendiente a la vez.</li>
                <li>El monto máximo es 10 veces tus ingresos mensuales.</li>
                <li>Tu solicitud será evaluada por un analista.</li>
            </ul>
        </div>
    </div>
</div>