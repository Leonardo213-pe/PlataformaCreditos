@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold">💳 Plataforma de Créditos</h1>
    <p class="lead text-muted">Gestión de solicitudes de crédito</p>
    <hr class="my-4" />

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <p class="fs-5">Bienvenido, <strong>@User.Identity.Name</strong></p>
        <div class="d-flex justify-content-center gap-3 mt-4">
            <a asp-controller="Solicitudes" asp-action="MisSolicitudes"
               class="btn btn-primary btn-lg">📋 Mis Solicitudes</a>
            <a asp-controller="Solicitudes" asp-action="Nueva"
               class="btn btn-success btn-lg">+ Nueva Solicitud</a>
            @if (User.IsInRole("Analista"))
            {
                <a asp-controller="Analista" asp-action="Index"
                   class="btn btn-warning btn-lg">⚙ Panel Analista</a>
            }
        </div>
    }
    else
    {
        <p class="fs-5 text-muted">
            Inicia sesión para gestionar tus solicitudes de crédito
        </p>
        <div class="d-flex justify-content-center gap-3 mt-4">
            <a href="/Identity/Account/Login"
               class="btn btn-primary btn-lg">Iniciar sesión</a>
            <a href="/Identity/Account/Register"
               class="btn btn-outline-primary btn-lg">Registrarse</a>
        </div>
    }
</div>

<div class="row mt-5 text-center">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body py-4">
                <div class="fs-1 mb-3">📝</div>
                <h5 class="card-title">Solicitar Crédito</h5>
                <p class="card-text text-muted">
                    Registra tu solicitud de forma rápida y segura.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body py-4">
                <div class="fs-1 mb-3">📊</div>
                <h5 class="card-title">Seguimiento</h5>
                <p class="card-text text-muted">
                    Consulta el estado de tus solicitudes en tiempo real.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body py-4">
                <div class="fs-1 mb-3">✅</div>
                <h5 class="card-title">Evaluación Rápida</h5>
                <p class="card-text text-muted">
                    Nuestros analistas evalúan con criterios claros.
                </p>
            </div>
        </div>
    </div>
</div>